	// SEARCH JOB
	@GetMapping("/search")
	public List<Job> searchJobs(@RequestParam String keyword) {

		return jobRepository.findByTitleContainingIgnoreCase(keyword);
	}

	// FILTER JOB
	@GetMapping("/filter")
	public List<Job> filterJobs(@RequestParam String location, @RequestParam Double salary) {

		return jobRepository.findByLocationAndSalary(location, salary);
	}
}